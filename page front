<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบเก็บตังค์กลุ่ม</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Prompt', sans-serif; }
        body { background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 99%, #fecfef 100%); min-height: 100vh; display: flex; justify-content: center; align-items: center; padding: 20px; }
        .glass-card { background: rgba(255, 255, 255, 0.25); box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37); backdrop-filter: blur(10px); border-radius: 20px; border: 1px solid rgba(255, 255, 255, 0.18); padding: 40px; width: 100%; max-width: 400px; text-align: center; color: #333; }
        h1 { font-size: 24px; margin-bottom: 10px; color: #fff; text-shadow: 1px 1px 2px rgba(0,0,0,0.2); }
        .balance { font-size: 48px; font-weight: bold; color: #fff; margin-bottom: 20px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2); }
        input { width: 100%; padding: 15px; margin-bottom: 20px; border: none; border-radius: 10px; font-size: 16px; text-align: center; outline: none; }
        button { width: 100%; padding: 15px; border: none; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; transition: 0.3s; color: white; margin-bottom: 10px; }
        .btn-login { background: #a18cd1; }
        .btn-login:hover { background: #fbc2eb; }
        .btn-group { display: flex; gap: 10px; }
        .btn-group button { flex: 1; margin-bottom: 0; }
        .btn-add { background: #4facfe; }
        .btn-add:hover { background: #00f2fe; }
        .btn-remove { background: #ff0844; }
        .btn-remove:hover { background: #ffb199; }
        .status { margin-top: 15px; font-size: 14px; color: #fff; }
        .user-info { color: #fff; font-size: 16px; margin-bottom: 15px; background: rgba(0,0,0,0.1); padding: 8px; border-radius: 8px; }
        #dashboard { display: none; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@400;600&display=swap" rel="stylesheet">
</head>
<body>

    <div class="glass-card" id="loginPage">
        <h1>เข้าสู่ระบบ 🔐</h1>
        <p style="color: #fff; margin-bottom: 20px;">กรุณากรอกรหัสนักศึกษาของแก</p>
        <input type="text" id="studentId" placeholder="เช่น 660101">
        <button class="btn-login" onclick="checkLogin()">เข้าสู่ระบบ</button>
        <div class="status" id="loginStatus"></div>
    </div>

    <div class="glass-card" id="dashboard">
        <div class="user-info" id="userInfoDisplay"></div>
        <h1>ยอดเงินคงเหลือ 💰</h1>
        <div class="balance" id="balanceDisplay">Loading...</div>
        <input type="number" id="amount" placeholder="ใส่จำนวนเงินตรงนี้">
        <div class="btn-group">
            <button class="btn-add" onclick="updateMoney('add')">+ เพิ่มเงิน</button>
            <button class="btn-remove" onclick="updateMoney('remove')">- หักเงิน</button>
        </div>
        <div class="status" id="statusText">กำลังรอคำสั่ง...</div>
    </div>

    <script>
        // แกจ๋า อย่าลืมลบคำข้างล่างนี้แล้วเอาลิงก์ Web App URL จากกูเกิลสคริปต์มาใส่ในเครื่องหมาย ' ' นะ!
        const scriptURL = 'YOUR_GOOGLE_APPS_SCRIPT_URL'; 

        async function checkLogin() {
            let stdId = document.getElementById('studentId').value;
            let loginStatus = document.getElementById('loginStatus');
            if(!stdId) { loginStatus.innerText = 'อย่าลืมกรอกรหัสนะแก!'; return; }
            loginStatus.innerText = 'กำลังตรวจรหัสแป๊บนึง... ⏳';
            try {
                let response = await fetch(scriptURL, { method: 'POST', body: JSON.stringify({ action: 'login', studentId: stdId }) });
                let data = await response.json();
                if(data.success) {
                    document.getElementById('loginPage').style.display = 'none';
                    document.getElementById('dashboard').style.display = 'block';
                    
                    // แสดงชื่อและเลขที่พอล็อกอินผ่าน
                    document.getElementById('userInfoDisplay').innerText = `สวัสดีแก! คุณ: ${data.user.name} (เลขที่ ${data.user.assignedNo})`;
                    
                    fetchBalance();
                } else {
                    loginStatus.innerText = 'ไม่มีรหัสนี้ในระบบอ่าแก ❌';
                }
            } catch (error) { loginStatus.innerText = 'ระบบเชื่อมต่อขัดข้อง ลองอีกทีนะ 😢'; }
        }

        async function fetchBalance() {
            try {
                let response = await fetch(scriptURL);
                let data = await response.json();
                document.getElementById('balanceDisplay').innerText = data.balance + ' ฿';
            } catch (error) { document.getElementById('balanceDisplay').innerText = 'Error'; }
        }

        async function updateMoney(action) {
            let amount = document.getElementById('amount').value;
            let statusText = document.getElementById('statusText');
            if(!amount || amount <= 0) { statusText.innerText = 'กรอกจำนวนเงินก่อนสิแก!'; return; }
            statusText.innerText = 'กำลังส่งข้อมูลเข้า Google Sheets... ⏳';
            let finalAmount = action === 'add' ? amount : -amount;
            try {
                let response = await fetch(scriptURL, { method: 'POST', body: JSON.stringify({ action: 'update', amount: finalAmount }) });
                let data = await response.json();
                if(data.success) {
                    document.getElementById('balanceDisplay').innerText = data.newBalance + ' ฿';
                    statusText.innerText = 'อัปเดตยอดเงินเรียบร้อยแล้ว! 🎉';
                    document.getElementById('amount').value = ''; 
                }
            } catch (error) { statusText.innerText = 'เกิดข้อผิดพลาดในการอัปเดตยอด 😢'; }
        }
    </script>
</body>
</html>
